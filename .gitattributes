# Zeilenenden projektweit auf LF normalisieren (verhindert CRLF-Diffs unter Windows)
* text=auto eol=lf

# Textbasierte Web-Quellen explizit als LF
*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.svg  text eol=lf
*.xml  text eol=lf
*.txt  text eol=lf
*.md   text eol=lf
# Erzeugte Dateien aus data/. build_data.py schreibt sie seit dem 21.07.2026
# selbst mit LF (siehe schreibe() dort); die Zeile hier ist die zweite
# Sicherung, falls sie doch einmal jemand von Hand anfasst.
*.json text eol=lf
CNAME  text eol=lf

# Binärdateien nie anfassen
*.png  binary
*.jpg  binary
*.jpeg binary
*.ico  binary
*.webp binary
*.woff  binary
*.woff2 binary
*.xlsx binary
*.xls  binary
*.pdf  binary
*.zip  binary
