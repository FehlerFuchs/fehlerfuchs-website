{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fehlerfuchs.eu/data/schema/product.schema.json",
  "title": "FehlerFuchs Produkt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "slug",
    "name",
    "fullName",
    "kind",
    "tagline",
    "description",
    "audience",
    "accent",
    "status",
    "platforms",
    "privacy",
    "links"
  ],
  "properties": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "name": {
      "type": "string",
      "minLength": 2,
      "maxLength": 60
    },
    "fullName": {
      "type": "string",
      "minLength": 2,
      "maxLength": 90
    },
    "kind": {
      "description": "produkt = fertige Anwendung · edition = Ausbaustufe eines Produkts · werkzeug = Zubehör · dienstleistung = wird erst auf Bestellung gebaut, es gibt sie also nicht zum Herunterladen",
      "enum": [
        "produkt",
        "edition",
        "werkzeug",
        "dienstleistung"
      ]
    },
    "standalone": {
      "type": "boolean"
    },
    "theme": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "modus"
      ],
      "description": "Farben der Produktseite, wenn sie die der App aufgreifen soll. Betrifft NUR den Inhaltsbereich – Kopfleiste, Navigation und Fußzeile bleiben FehlerFuchs. Die Seite soll die App zeigen, nicht so tun, als sei sie die App. Fehlt der Block, gilt das helle Standardbild.",
      "properties": {
        "modus": {
          "enum": [
            "hell",
            "dunkel"
          ],
          "description": "Grundstimmung. Bestimmt auch, wogegen die Prüfung den Kontrast rechnet."
        },
        "hintergrund": {
          "type": "string",
          "pattern": "^#[0-9A-Fa-f]{6}$"
        },
        "flaeche": {
          "type": "string",
          "pattern": "^#[0-9A-Fa-f]{6}$",
          "description": "Karten, Tabellen, abgesetzte Blöcke."
        },
        "rand": {
          "type": "string",
          "pattern": "^#[0-9A-Fa-f]{6}$"
        },
        "text": {
          "type": "string",
          "pattern": "^#[0-9A-Fa-f]{6}$"
        },
        "textLeise": {
          "type": "string",
          "pattern": "^#[0-9A-Fa-f]{6}$"
        },
        "akzent": {
          "type": "string",
          "pattern": "^#[0-9A-Fa-f]{6}$",
          "description": "Akzent NUR für diese Seite. Auf dunklem Grund braucht es oft einen helleren Ton als 'accent', der in Listen und Karten auf hellem Grund gilt."
        },
        "quelle": {
          "type": "string",
          "maxLength": 200,
          "description": "Woher die Werte stammen, etwa der Pfad zur theme.dart der App. Damit später nachvollziehbar ist, warum genau diese Töne."
        }
      }
    },
    "statusGrund": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "wenn",
        "text"
      ],
      "description": "Der persönliche Grund für den derzeitigen Stand, in eigenen Worten. Eine Statusstufe sagt WAS, nicht WARUM – und „Pausiert\" allein liest sich, als sei das Projekt tot. Damit dieser Satz nicht veraltet, trägt er unter 'wenn', zu welchem Status er gehört: Passt er nicht mehr, wird er nicht angezeigt und die Prüfung meldet ihn.",
      "properties": {
        "wenn": {
          "enum": [
            "verfuegbar",
            "pruefung",
            "beta",
            "alpha",
            "entwicklung",
            "konzept",
            "idee",
            "pausiert",
            "eingestellt"
          ],
          "description": "Der Status, zu dem dieser Satz gehört."
        },
        "text": {
          "type": "string",
          "minLength": 20,
          "maxLength": 400,
          "description": "Zwei, drei Sätze. Warm und ehrlich, keine langen Reden."
        }
      }
    },
    "umwege": {
      "type": "array",
      "description": "Rückschläge, die den Weg verändert haben. WICHTIG, damit dieses Feld nicht dasselbe Schicksal erleidet wie eine handgepflegte Meilensteinliste: Hier stehen ausschließlich abgeschlossene EREIGNISSE der Vergangenheit, nie der aktuelle Stand. Wo ein Produkt gerade steht, sagt platforms[].status – und nur der.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "datum",
          "os",
          "von",
          "grund"
        ],
        "properties": {
          "datum": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "os": {
            "enum": [
              "windows",
              "android",
              "ios",
              "linux",
              "macos",
              "web"
            ],
            "description": "Welche Plattform es traf. Ein Umweg betrifft selten alle."
          },
          "von": {
            "enum": [
              "verfuegbar",
              "pruefung",
              "beta",
              "alpha",
              "entwicklung",
              "konzept"
            ],
            "description": "Wo es stand, als es schiefging."
          },
          "nach": {
            "enum": [
              "verfuegbar",
              "pruefung",
              "beta",
              "alpha",
              "entwicklung",
              "konzept"
            ],
            "description": "Wohin es zurückging. Muss früher auf dem Weg liegen als 'von' – sonst wäre es kein Umweg. Gleich 'von' bedeutet eine SCHLEIFE: Es ging nichts zurueck, der Weg wurde nur noch einmal gegangen - typisch bei einer Ablehnung, gegen die Widerspruch laeuft. Entfaellt, wenn ein 'zwischenschritt' angegeben ist - dann fuehrt der Weg dorthin."
          },
          "grund": {
            "type": "string",
            "minLength": 4,
            "maxLength": 60,
            "description": "In wenigen Worten, etwa „Ablehnung durch Google Play\". Steht als Etikett an der Kehre."
          },
          "text": {
            "type": "string",
            "maxLength": 600,
            "description": "Was genau passierte und was daraus wurde. Zwei bis vier Sätze – ein Rückschlag verdient eine Erklärung, keine Stichworte."
          },
          "zwischenschritt": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name"
            ],
            "description": "Ein Schritt, den es OHNE diesen Umweg nicht gaebe - etwa eine Nachreichung. Er gehoert bewusst NICHT in statuses.yaml: dort stehen die Stufen, die jede Anwendung durchlaeuft. Er sitzt unmittelbar vor dem Schritt, an dem es scheiterte, und der neue Ast der Gabelung fuehrt in ihn hinein.",
            "properties": {
              "name": {
                "type": "string",
                "minLength": 4,
                "maxLength": 48
              },
              "datum": {
                "type": "string",
                "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
              },
              "erledigt": {
                "type": "boolean",
                "description": "Ist der Zwischenschritt schon getan? Sonst gilt er als laufend."
              }
            }
          }
        }
      }
    },
    "parent": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "tagline": {
      "type": "string",
      "minLength": 10,
      "maxLength": 200
    },
    "description": {
      "type": "string",
      "minLength": 40,
      "maxLength": 600
    },
    "audience": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "privat",
          "selbststaendige",
          "unternehmen",
          "vereine"
        ]
      }
    },
    "accent": {
      "type": "string",
      "pattern": "^#[0-9A-Fa-f]{6}$"
    },
    "wordmark": {
      "$ref": "#/$defs/wortmarke"
    },
    "status": {
      "enum": [
        "verfuegbar",
        "pruefung",
        "beta",
        "alpha",
        "entwicklung",
        "konzept",
        "idee",
        "pausiert",
        "eingestellt"
      ]
    },
    "platforms": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "os",
          "status",
          "distribution"
        ],
        "properties": {
          "os": {
            "enum": [
              "windows",
              "android",
              "ios",
              "linux",
              "macos",
              "web"
            ]
          },
          "status": {
            "enum": [
              "verfuegbar",
              "pruefung",
              "beta",
              "alpha",
              "entwicklung",
              "konzept",
              "idee",
              "pausiert",
              "eingestellt"
            ]
          },
          "requirements": {
            "type": "string"
          },
          "distribution": {
            "enum": [
              "play-store",
              "github-release",
              "digistore24",
              "im-browser",
              "auf-anfrage",
              "keiner"
            ]
          },
          "storeId": {
            "type": "string"
          },
          "since": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "hinweis": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "wenn",
              "text"
            ],
            "description": "Ein Satz zu GENAU DIESER Plattform, in eigenen Worten. Fuer den Fall, dass eine Statusstufe zwar stimmt, aber nicht erklaert, warum es dort haengt. Wie bei statusGrund traegt er unter 'wenn', zu welchem Plattform-Status er gehoert: passt er nicht mehr, verschwindet er und die Pruefung meldet ihn. Ein Satz ohne diese Bindung veraltet still.",
            "properties": {
              "wenn": {
                "enum": [
                  "verfuegbar",
                  "pruefung",
                  "beta",
                  "alpha",
                  "entwicklung",
                  "konzept",
                  "idee",
                  "pausiert",
                  "eingestellt"
                ]
              },
              "text": {
                "type": "string",
                "minLength": 30,
                "maxLength": 700
              }
            }
          }
        }
      }
    },
    "privacy": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "enum": [
          "nur-lokal",
          "keine-cloud",
          "kein-konto",
          "kein-tracking",
          "werbefrei",
          "kein-google",
          "eigener-sync",
          "offline-faehig"
        ]
      }
    },
    "editions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "public",
          "price"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "name": {
            "type": "string"
          },
          "public": {
            "type": "boolean"
          },
          "summary": {
            "type": "string",
            "maxLength": 300
          },
          "price": {
            "$ref": "#/$defs/price"
          },
          "emphasis": {
            "type": "boolean"
          },
          "wordmark": {
            "$ref": "#/$defs/wortmarke"
          }
        }
      }
    },
    "releases": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "version",
          "date",
          "channel",
          "os",
          "url",
          "filename",
          "size",
          "sha256",
          "signed"
        ],
        "properties": {
          "version": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+\\.\\d+$"
          },
          "date": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "channel": {
            "enum": [
              "stable",
              "beta",
              "alpha"
            ]
          },
          "os": {
            "enum": [
              "windows",
              "android",
              "ios",
              "linux",
              "macos",
              "web"
            ]
          },
          "url": {
            "type": "string",
            "format": "uri",
            "pattern": "^https://"
          },
          "filename": {
            "type": "string"
          },
          "size": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "bytes",
              "label",
              "source"
            ],
            "properties": {
              "bytes": {
                "type": [
                  "integer",
                  "null"
                ],
                "minimum": 1
              },
              "label": {
                "type": "string"
              },
              "source": {
                "type": "string"
              }
            }
          },
          "sha256": {
            "type": [
              "string",
              "null"
            ],
            "pattern": "^[0-9a-f]{64}$"
          },
          "signed": {
            "type": "boolean"
          },
          "notes": {
            "type": "string",
            "maxLength": 600
          }
        }
      }
    },
    "links": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "page"
      ],
      "properties": {
        "page": {
          "type": "string",
          "pattern": "^/"
        },
        "store": {
          "type": "string",
          "pattern": "^https://"
        },
        "release": {
          "type": "string",
          "pattern": "^https://"
        },
        "betaSignup": {
          "type": "string",
          "pattern": "^https://"
        },
        "checkout": {
          "type": "string",
          "pattern": "^https://"
        },
        "contact": {
          "type": "string",
          "pattern": "^/"
        }
      }
    },
    "features": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "group",
          "items"
        ],
        "properties": {
          "group": {
            "type": "string",
            "minLength": 2,
            "maxLength": 60
          },
          "items": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "name",
                "values"
              ],
              "properties": {
                "name": {
                  "type": "string",
                  "minLength": 3,
                  "maxLength": 160
                },
                "note": {
                  "type": "string",
                  "maxLength": 300
                },
                "values": {
                  "type": "object",
                  "minProperties": 1,
                  "additionalProperties": {
                    "oneOf": [
                      {
                        "enum": [
                          "ja",
                          "nein",
                          "optional",
                          "teilweise",
                          "geplant",
                          "in-arbeit",
                          "in-vorbereitung"
                        ]
                      },
                      {
                        "type": "string",
                        "minLength": 1,
                        "maxLength": 60
                      }
                    ]
                  }
                }
              }
            }
          }
        }
      }
    },
    "faq": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "question",
          "answer"
        ],
        "properties": {
          "question": {
            "type": "string",
            "minLength": 6,
            "maxLength": 160
          },
          "answer": {
            "type": "string",
            "minLength": 20,
            "maxLength": 1200
          }
        }
      }
    },
    "media": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "lockup": {
          "$ref": "#/$defs/bild"
        },
        "og": {
          "$ref": "#/$defs/bild"
        },
        "screenshots": {
          "type": "array",
          "maxItems": 12,
          "description": "Bilder aus der laufenden Anwendung. Zeigen, was Worte nur behaupten können. Reihenfolge = Reihenfolge auf der Seite; das erste ist zugleich das Vorschaubild.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "src",
              "alt",
              "width",
              "height"
            ],
            "properties": {
              "src": {
                "type": "string",
                "pattern": "^/img/"
              },
              "alt": {
                "type": "string",
                "minLength": 10,
                "maxLength": 200,
                "description": "Was auf dem Bild zu sehen ist – für Menschen, die es nicht sehen können, und für Suchmaschinen. 'Screenshot' allein ist keine Beschreibung."
              },
              "width": {
                "type": "integer",
                "minimum": 1
              },
              "height": {
                "type": "integer",
                "minimum": 1
              },
              "titel": {
                "type": "string",
                "maxLength": 80,
                "description": "Bildunterschrift. Sagt, worauf man achten soll."
              },
              "geraet": {
                "enum": [
                  "handy",
                  "tablet",
                  "desktop"
                ],
                "description": "Steuert die Darstellung: Handybilder sind hoch und schmal, Desktopbilder breit."
              }
            }
          }
        },
        "platzhalter": {
          "type": [
            "integer",
            "boolean"
          ],
          "minimum": 1,
          "maximum": 8,
          "description": "Statt Bildschirmfotos Platzhalter aus dem Motivsatz zeigen. Zahl = wie viele. Die Auswahl haengt am Produktnamen und ist deshalb bei jedem Bau dieselbe. Wirkt nur, wenn 'screenshots' fehlt oder leer ist - echte Bilder haben immer Vorrang."
        }
      }
    },
    "manifests": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "updateFeed": {
          "type": "string"
        }
      }
    },
    "notes": {
      "type": "string"
    },
    "customPage": {
      "type": "boolean"
    }
  },
  "$defs": {
    "bild": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "src",
        "alt",
        "width",
        "height"
      ],
      "properties": {
        "src": {
          "type": "string",
          "pattern": "^/"
        },
        "alt": {
          "type": "string",
          "minLength": 5,
          "maxLength": 300
        },
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        },
        "caption": {
          "type": "string",
          "maxLength": 300
        }
      }
    },
    "price": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model"
      ],
      "properties": {
        "model": {
          "enum": [
            "kostenlos",
            "einmalig",
            "iap",
            "staffel",
            "auf-anfrage",
            "offen"
          ]
        },
        "amount": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "currency": {
          "enum": [
            "EUR"
          ]
        },
        "vatIncluded": {
          "type": "boolean"
        },
        "recurring": {
          "type": "boolean"
        },
        "tiers": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "seats",
              "amount",
              "perSeat"
            ],
            "properties": {
              "seats": {
                "type": "integer",
                "minimum": 1
              },
              "amount": {
                "type": "number",
                "minimum": 0
              },
              "perSeat": {
                "type": "number",
                "minimum": 0
              },
              "discountPercent": {
                "type": "integer",
                "minimum": 0,
                "maximum": 100
              },
              "checkout": {
                "type": "string",
                "pattern": "^https://"
              },
              "badge": {
                "type": "string",
                "maxLength": 30
              }
            }
          }
        }
      }
    },
    "wortmarke": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "text"
        ],
        "properties": {
          "text": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40
          },
          "color": {
            "type": "string",
            "pattern": "^#[0-9A-Fa-f]{6}$"
          },
          "weight": {
            "enum": [
              "normal",
              "bold"
            ]
          },
          "break": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
