{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fehlerfuchs.eu/data/schema/product.schema.json",
  "title": "FehlerFuchs Produkt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "slug",
    "name",
    "fullName",
    "kind",
    "tagline",
    "description",
    "audience",
    "accent",
    "status",
    "platforms",
    "privacy",
    "links"
  ],
  "properties": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "name": {
      "type": "string",
      "minLength": 2,
      "maxLength": 60
    },
    "fullName": {
      "type": "string",
      "minLength": 2,
      "maxLength": 90
    },
    "kind": {
      "description": "produkt = fertige Anwendung · edition = Ausbaustufe eines Produkts · werkzeug = Zubehör · dienstleistung = wird erst auf Bestellung gebaut, es gibt sie also nicht zum Herunterladen",
      "enum": [
        "produkt",
        "edition",
        "werkzeug",
        "dienstleistung"
      ]
    },
    "standalone": {
      "type": "boolean"
    },
    "parent": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "tagline": {
      "type": "string",
      "minLength": 10,
      "maxLength": 200
    },
    "description": {
      "type": "string",
      "minLength": 40,
      "maxLength": 600
    },
    "audience": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "privat",
          "selbststaendige",
          "unternehmen",
          "vereine"
        ]
      }
    },
    "accent": {
      "type": "string",
      "pattern": "^#[0-9A-Fa-f]{6}$"
    },
    "wordmark": {
      "$ref": "#/$defs/wortmarke"
    },
    "status": {
      "enum": [
        "verfuegbar",
        "pruefung",
        "beta",
        "alpha",
        "entwicklung",
        "konzept",
        "idee",
        "pausiert",
        "eingestellt"
      ]
    },
    "platforms": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "os",
          "status",
          "distribution"
        ],
        "properties": {
          "os": {
            "enum": [
              "windows",
              "android",
              "ios",
              "linux",
              "macos",
              "web"
            ]
          },
          "status": {
            "enum": [
              "verfuegbar",
              "pruefung",
              "beta",
              "alpha",
              "entwicklung",
              "konzept",
              "idee",
              "pausiert",
              "eingestellt"
            ]
          },
          "requirements": {
            "type": "string"
          },
          "distribution": {
            "enum": [
              "play-store",
              "github-release",
              "digistore24",
              "im-browser",
              "auf-anfrage",
              "keiner"
            ]
          },
          "storeId": {
            "type": "string"
          },
          "since": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          }
        }
      }
    },
    "privacy": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "enum": [
          "nur-lokal",
          "keine-cloud",
          "kein-konto",
          "kein-tracking",
          "werbefrei",
          "kein-google",
          "eigener-sync",
          "offline-faehig"
        ]
      }
    },
    "editions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "public",
          "price"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "name": {
            "type": "string"
          },
          "public": {
            "type": "boolean"
          },
          "summary": {
            "type": "string",
            "maxLength": 300
          },
          "price": {
            "$ref": "#/$defs/price"
          },
          "emphasis": {
            "type": "boolean"
          },
          "wordmark": {
            "$ref": "#/$defs/wortmarke"
          }
        }
      }
    },
    "releases": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "version",
          "date",
          "channel",
          "os",
          "url",
          "filename",
          "size",
          "sha256",
          "signed"
        ],
        "properties": {
          "version": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+\\.\\d+$"
          },
          "date": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "channel": {
            "enum": [
              "stable",
              "beta",
              "alpha"
            ]
          },
          "os": {
            "enum": [
              "windows",
              "android",
              "ios",
              "linux",
              "macos",
              "web"
            ]
          },
          "url": {
            "type": "string",
            "format": "uri",
            "pattern": "^https://"
          },
          "filename": {
            "type": "string"
          },
          "size": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "bytes",
              "label",
              "source"
            ],
            "properties": {
              "bytes": {
                "type": [
                  "integer",
                  "null"
                ],
                "minimum": 1
              },
              "label": {
                "type": "string"
              },
              "source": {
                "type": "string"
              }
            }
          },
          "sha256": {
            "type": [
              "string",
              "null"
            ],
            "pattern": "^[0-9a-f]{64}$"
          },
          "signed": {
            "type": "boolean"
          },
          "notes": {
            "type": "string",
            "maxLength": 600
          }
        }
      }
    },
    "links": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "page"
      ],
      "properties": {
        "page": {
          "type": "string",
          "pattern": "^/"
        },
        "store": {
          "type": "string",
          "pattern": "^https://"
        },
        "release": {
          "type": "string",
          "pattern": "^https://"
        },
        "betaSignup": {
          "type": "string",
          "pattern": "^https://"
        },
        "checkout": {
          "type": "string",
          "pattern": "^https://"
        },
        "contact": {
          "type": "string",
          "pattern": "^/"
        }
      }
    },
    "features": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "group",
          "items"
        ],
        "properties": {
          "group": {
            "type": "string",
            "minLength": 2,
            "maxLength": 60
          },
          "items": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "name",
                "values"
              ],
              "properties": {
                "name": {
                  "type": "string",
                  "minLength": 3,
                  "maxLength": 160
                },
                "note": {
                  "type": "string",
                  "maxLength": 300
                },
                "values": {
                  "type": "object",
                  "minProperties": 1,
                  "additionalProperties": {
                    "oneOf": [
                      {
                        "enum": [
                          "ja",
                          "nein",
                          "optional",
                          "teilweise",
                          "geplant",
                          "in-arbeit",
                          "in-vorbereitung"
                        ]
                      },
                      {
                        "type": "string",
                        "minLength": 1,
                        "maxLength": 60
                      }
                    ]
                  }
                }
              }
            }
          }
        }
      }
    },
    "faq": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "question",
          "answer"
        ],
        "properties": {
          "question": {
            "type": "string",
            "minLength": 6,
            "maxLength": 160
          },
          "answer": {
            "type": "string",
            "minLength": 20,
            "maxLength": 1200
          }
        }
      }
    },
    "media": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "lockup": {
          "$ref": "#/$defs/bild"
        },
        "og": {
          "$ref": "#/$defs/bild"
        },
        "screenshots": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/bild"
          }
        }
      }
    },
    "manifests": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "updateFeed": {
          "type": "string"
        }
      }
    },
    "notes": {
      "type": "string"
    },
    "customPage": {
      "type": "boolean"
    }
  },
  "$defs": {
    "bild": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "src",
        "alt",
        "width",
        "height"
      ],
      "properties": {
        "src": {
          "type": "string",
          "pattern": "^/"
        },
        "alt": {
          "type": "string",
          "minLength": 5,
          "maxLength": 300
        },
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        },
        "caption": {
          "type": "string",
          "maxLength": 300
        }
      }
    },
    "price": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model"
      ],
      "properties": {
        "model": {
          "enum": [
            "kostenlos",
            "einmalig",
            "iap",
            "staffel",
            "auf-anfrage",
            "offen"
          ]
        },
        "amount": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "currency": {
          "enum": [
            "EUR"
          ]
        },
        "vatIncluded": {
          "type": "boolean"
        },
        "recurring": {
          "type": "boolean"
        },
        "tiers": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "seats",
              "amount",
              "perSeat"
            ],
            "properties": {
              "seats": {
                "type": "integer",
                "minimum": 1
              },
              "amount": {
                "type": "number",
                "minimum": 0
              },
              "perSeat": {
                "type": "number",
                "minimum": 0
              },
              "discountPercent": {
                "type": "integer",
                "minimum": 0,
                "maximum": 100
              },
              "checkout": {
                "type": "string",
                "pattern": "^https://"
              },
              "badge": {
                "type": "string",
                "maxLength": 30
              }
            }
          }
        }
      }
    },
    "wortmarke": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "text"
        ],
        "properties": {
          "text": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40
          },
          "color": {
            "type": "string",
            "pattern": "^#[0-9A-Fa-f]{6}$"
          },
          "weight": {
            "enum": [
              "normal",
              "bold"
            ]
          },
          "break": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
